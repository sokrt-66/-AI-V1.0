# 轻企AI智能办公系统 V1.0 配置文件
# 复制本文件为 .env 后填入实际配置

# ============================================================
# 系统基本配置
# ============================================================
APP_NAME=轻企AI智能办公系统
APP_VERSION=1.0.0
APP_PORT=8000
APP_HOST=0.0.0.0
DEBUG=true

# ============================================================
# AI模型调用模式: cloud | local (Ollama)
# ============================================================
AI_MODE=cloud

# ============================================================
# ============================================================
# 云端密钥大模型配置 (AI_MODE=cloud 时生效)
# ============================================================
# API 地址（支持 OpenAI 兼容协议）：
#   - http://localhost:3000     （本地代理，如 one-api / NewAPI / Docker 等）
#   - https://api.openai.com/v1 （OpenAI 官方）
#   - 其他第三方兼容接口
CLOUD_API_KEY=sk-your-api-key-here
CLOUD_API_BASE=http://localhost:3000

# 模型名称（根据实际 API 渠道填写）
#   DeepSeek: DeepSeek-V4-Flash
#   OpenAI  : gpt-4o / gpt-4o-mini / gpt-3.5-turbo
#   其他代理: 查看你的代理管理界面配置的模型名
CLOUD_MODEL_NAME=DeepSeek-V4-Flash
CLOUD_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================
# Ollama 本地模型配置 (AI_MODE=local 时生效)
# ============================================================
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL_NAME=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=bge-m3

# ============================================================
# RAG 参数
# ============================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=6
TEMPERATURE=0.3
MAX_TOKENS=2048

# ============================================================
# Token 限流与统计
# ============================================================
TOKEN_DAILY_LIMIT=10000000
ENABLE_TOKEN_STATS=true

# ============================================================
# 存储路径
# ============================================================
STORAGE_BASE=./storage
UPLOAD_DIR=./storage/uploads
EXPORT_DIR=./storage/exports
LOG_DIR=./storage/logs
